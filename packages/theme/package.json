{
  "name": "@emdzej/bimmerz-theme",
  "version": "0.1.0",
  "type": "module",
  "description": "Shared Tailwind preset + CSS variables for the bimmerz app family — zinc-based light/dark token system, per-app accent override.",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./tokens.css": "./tokens.css"
  },
  "files": [
    "dist",
    "tokens.css"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "peerDependencies": {
    "tailwindcss": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/emdzej/bimmerz-core.git",
    "directory": "packages/theme"
  }
}
