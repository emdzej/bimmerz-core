{
  "name": "@emdzej/bimmerz-ignore",
  "version": "0.1.0",
  "type": "module",
  "description": "Gitignore-style file filtering and directory walking for bimmerz tools — wraps the `ignore` package with case-insensitive matching and an async walker.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "ignore": "^5.3.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/emdzej/bimmerz-core.git",
    "directory": "packages/ignore"
  }
}
