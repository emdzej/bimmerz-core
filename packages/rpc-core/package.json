{
  "name": "@emdzej/bimmerz-rpc-core",
  "version": "0.1.0",
  "type": "module",
  "description": "JSON-RPC 2.0 over WebSocket client used by the bimmerz-box dongle's /rpc endpoints. Transport-only — protocol-specific clients (UART, CAN, ...) build on top.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "typescript": "^5.7.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/emdzej/bimmerz.git",
    "directory": "packages/rpc-core"
  }
}
